{% extends 'base.html.twig' %}

{% block title %}Adoption Request — PAWHUB{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Main Container */
        .adoption-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 1.5rem;
        }
        
        /* Header Section */
        .adoption-header {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            margin-bottom: 2.5rem;
        }
        
        @media (min-width: 768px) {
            .adoption-header {
                flex-direction: row;
                justify-content: space-between;
                align-items: center;
            }
        }
        
        .adoption-header h1 {
            color: var(--gray-900);
            font-size: 2rem;
            font-weight: 700;
            margin: 0;
            line-height: 1.2;
        }
        
        /* Action Buttons */
        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
        }
        
        /* Detail Sections */
        .adoption-details {
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            overflow: hidden;
            margin-bottom: 2rem;
        }
        
        .detail-section {
            padding: 1.5rem;
            border-bottom: 1px solid var(--gray-200);
        }
        
        .detail-section:last-child {
            border-bottom: none;
        }
        
        .section-title {
            color: var(--gray-700);
            font-size: 1.125rem;
            font-weight: 600;
            margin: 0 0 1.25rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid var(--gray-100);
        }
        
        .section-title svg {
            width: 1.25rem;
            height: 1.25rem;
            color: var(--primary);
        }
        
        /* Detail Grid */
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 1.5rem;
        }
        
        .detail-item {
            margin-bottom: 1.25rem;
        }
        
        .detail-label {
            display: block;
            color: var(--gray-600);
            font-size: 0.875rem;
            font-weight: 500;
            margin-bottom: 0.375rem;
            text-transform: uppercase;
            letter-spacing: 0.025em;
        }
        
        .detail-value {
            color: var(--gray-900);
            font-size: 1rem;
            font-weight: 500;
            line-height: 1.6;
            word-break: break-word;
        }
        
        /* Status Badges */
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.4em 0.8em;
            font-size: 0.8125rem;
            font-weight: 600;
            line-height: 1.25;
            border-radius: var(--radius-full);
            text-transform: capitalize;
        }
        
        .status-pending {
            background-color: var(--yellow-100);
            color: var(--yellow-800);
        }
        
        .status-approved {
            background-color: var(--green-100);
            color: var(--green-800);
        }
        
        .status-rejected {
            background-color: var(--red-100);
            color: var(--red-800);
        }
        
        /* Pet Card */
        .pet-card {
            background: white;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow);
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        
        .pet-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        
        .pet-image-container {
            position: relative;
            height: 220px;
            overflow: hidden;
        }
        
        .pet-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }
        
        .pet-card:hover .pet-image {
            transform: scale(1.03);
        }
        
        .pet-status {
            position: absolute;
            top: 1rem;
            right: 1rem;
            z-index: 10;
        }
        
        .no-image {
            display: flex;
            align-items: center;
            justify-content: center;
            height: 220px;
            background: linear-gradient(135deg, var(--gray-100) 0%, var(--gray-200) 100%);
            color: var(--gray-400);
        }
        
        .no-image i {
            font-size: 3rem;
            opacity: 0.5;
        }
        
        .pet-card-body {
            padding: 1.5rem;
        }
        
        .pet-name {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--gray-900);
            margin: 0 0 0.5rem 0;
            line-height: 1.2;
        }
        
        .pet-breed {
            display: inline-block;
            background: var(--primary-50);
            color: var(--primary-700);
            font-size: 0.8125rem;
            font-weight: 500;
            padding: 0.25rem 0.75rem;
            border-radius: var(--radius-full);
            margin-bottom: 1rem;
        }
        
        .pet-description {
            color: var(--gray-600);
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        
        .pet-details {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 1px solid var(--gray-100);
        }
        
        .pet-detail-item {
            display: flex;
            margin-bottom: 0.75rem;
            font-size: 0.9375rem;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        
        .pet-detail-label {
            color: var(--gray-600);
            min-width: 120px;
            flex-shrink: 0;
            font-weight: 500;
        }
        
        .pet-detail-value {
            color: var(--gray-800);
            font-weight: 500;
            flex: 1;
            min-width: 0;
        }
        
        /* Adoption Info */
        .adoption-info {
            background: var(--gray-50);
            border-radius: var(--radius);
            padding: 1.5rem;
            margin-top: 1.5rem;
        }
        
        .adoption-info-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--gray-700);
            margin: 0 0 1rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .adoption-info-title i {
            color: var(--primary);
        }
        
        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .adoption-container {
                padding: 1.25rem 1rem;
            }
            
            .adoption-header {
                margin-bottom: 1.5rem;
            }
            
            .adoption-header h1 {
                font-size: 1.75rem;
            }
            
            .action-buttons {
                width: 100%;
            }
            
            .btn {
                flex: 1;
                min-width: 100%;
            }
            
            .detail-section {
                padding: 1.25rem;
            }
            
            .section-title {
                font-size: 1.125rem;
                margin-bottom: 1rem;
            }
            
            .pet-detail-item {
                flex-direction: column;
                gap: 0.25rem;
                margin-bottom: 1rem;
            }
            
            .pet-detail-label {
                min-width: 100%;
            }
            
            .pet-card-body {
                padding: 1.25rem;
            }
            
            .pet-name {
                font-size: 1.375rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="adoption-container">
    <div class="adoption-header">
        <h1>Adoption Request Details</h1>
        <div class="action-buttons">
            <a href="{{ path('app_adoption_edit', {id: adoption.id}) }}" class="btn btn-primary">
                <i class="fas fa-edit mr-2"></i> Edit Request
            </a>
            <form method="post" action="{{ path('app_adoption_delete', {id: adoption.id}) }}" onsubmit="return confirm('Are you sure you want to delete this adoption request? This action cannot be undone.')" class="m-0">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ adoption.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash-alt mr-2"></i> Delete Request
                </button>
            </form>
        </div>
    </div>

    <!-- Pet Information -->
    <div class="pet-card mb-6">
        {% if adoption.pet and adoption.pet.image %}
            <div class="pet-image-container">
                <img src="{{ asset('uploads/pets/' ~ adoption.pet.image) }}" alt="{{ adoption.pet.name|default('Pet') }}" class="pet-image">
                <div class="pet-status">
                    <span class="status-badge status-{{ adoption.status|lower }}">
                        {{ adoption.status }}
                    </span>
                </div>
            </div>
        {% else %}
            <div class="no-image">
                <i class="fas fa-paw"></i>
            </div>
        {% endif %}
        
        <div class="pet-card-body">
            <h2 class="pet-name">
                {% if adoption.pet %}
                    {{ adoption.pet.name|default('Unnamed Pet') }}
                {% else %}
                    Pet Information Not Available
                {% endif %}
            </h2>
            
            {% if adoption.pet %}
                <span class="pet-breed">{{ adoption.pet.breed|default('Breed not specified') }}</span>
                
                {% if adoption.pet.description %}
                    <p class="pet-description">{{ adoption.pet.description }}</p>
                {% endif %}
                
                <div class="pet-details">
                    <div class="pet-detail-item">
                        <span class="pet-detail-label">Age:</span>
                        <span class="pet-detail-value">{{ adoption.pet.age|default('N/A') }} years</span>
                    </div>
                    <div class="pet-detail-item">
                        <span class="pet-detail-label">Gender:</span>
                        <span class="pet-detail-value">{{ adoption.pet.gender|default('N/A')|capitalize }}</span>
                    </div>
                    <div class="pet-detail-item">
                        <span class="pet-detail-label">Size:</span>
                        <span class="pet-detail-value">{{ adoption.pet.size|default('N/A')|capitalize }}</span>
                    </div>
                </div>
            {% else %}
                <p class="text-gray-500">No pet information available for this adoption request.</p>
            {% endif %}
        </div>
    </div>

    <!-- Adoption Request Details -->
    <div class="adoption-details">
        <!-- Requester Information -->
        <div class="detail-section">
            <h3 class="section-title">
                <i class="fas fa-user"></i>
                Requester Information
            </h3>
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="detail-label">Full Name</span>
                    <p class="detail-value">{{ adoption.fullName|default('N/A') }}</p>
                </div>
                {% if adoption.user.username is defined %}
                <div class="detail-item">
                    <span class="detail-label">Email</span>
                    <p class="detail-value">{{ adoption.user.username|default('Not provided') }}</p>
                </div>
                {% endif %}
                {% if adoption.user.phone is defined %}
                <div class="detail-item">
                    <span class="detail-label">Phone</span>
                    <p class="detail-value">{{ adoption.user.phone|default('Not provided') }}</p>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Home and Household -->
        <div class="detail-section">
            <h3 class="section-title">
                <i class="fas fa-home"></i>
                Home and Household
            </h3>
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="detail-label">Residence Type</span>
                    <p class="detail-value">{{ adoption.residenceType|default('N/A')|title }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Household Members</span>
                    <p class="detail-value">{{ adoption.householdMembers|default('N/A') }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Landlord Approval</span>
                    <p class="detail-value">{{ adoption.homeAgreement ? 'Yes' : 'No' }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Yard Size</span>
                    <p class="detail-value">{{ adoption.yardSize|default('N/A') }}</p>
                </div>
            </div>
        </div>

        <!-- Pet Experience -->
        <div class="detail-section">
            <h3 class="section-title">
                <i class="fas fa-paw"></i>
                Pet Experience
            </h3>
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="detail-label">Current Pets</span>
                    <p class="detail-value">{{ adoption.currentPets|default('None') }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Previous Pets</span>
                    <p class="detail-value">{{ adoption.previousPets|default('None') }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Spay/Neuter Awareness</span>
                    <p class="detail-value">{{ adoption.spayNeuter ? 'Yes' : 'No' }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Experience Level</span>
                    <p class="detail-value">{{ adoption.petExperience|default('N/A')|title }}</p>
                </div>
            </div>
        </div>

        <!-- Pet Care -->
        <div class="detail-section">
            <h3 class="section-title">
                <i class="fas fa-heart"></i>
                Pet Care & Commitment
            </h3>
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="detail-label">Daily Schedule</span>
                    <p class="detail-value">{{ adoption.dailySchedule|default('N/A')|nl2br }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Financial Responsibility</span>
                    <p class="detail-value">{{ adoption.financials|default('N/A')|nl2br }}</p>
                </div>
                <div class="detail-item">
                    <span class="detail-label">Contingency Plan</span>
                    <p class="detail-value">{{ adoption.contingencyPlan|default('N/A')|nl2br }}</p>
                </div>
                <!-- Veterinarian information not available in this version -->
            </div>
        </div>

        <!-- Notes -->
        {% if adoption.notes %}
        <div class="detail-section">
            <h3 class="section-title">
                <i class="fas fa-edit"></i>
                Notes
            </h3>
            <div class="detail-item">
                <p class="detail-value">{{ adoption.notes|nl2br }}</p>
            </div>
        </div>
        {% endif %}

        <!-- Admin functionality can be added here in the future if needed -->

        <!-- Status and Dates -->
        <div class="detail-section bg-gray-50">
            <div class="detail-grid">
                <div class="detail-item">
                    <span class="detail-label">Requested On</span>
                    <p class="detail-value">{{ adoption.createdAt|date('F j, Y') }}</p>
                </div>
                {% if adoption.status == 'Approved' and adoption.approvedAt is defined %}
                <div class="detail-item">
                    <span class="detail-label">Approved On</span>
                    <p class="detail-value">{{ adoption.approvedAt|date('F j, Y') }}</p>
                </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Admin Actions -->
    {% if is_granted('ROLE_ADMIN') %}
    <div class="admin-actions mt-6 p-6 bg-white rounded-lg shadow">
        <h3 class="section-title">
            <i class="fas fa-user-shield"></i>
            Admin Actions
        </h3>
        <div class="action-buttons flex flex-wrap gap-4">
            <a href="{{ path('app_adoption_edit', {id: adoption.id}) }}" class="btn btn-primary">
                <i class="fas fa-edit mr-2"></i> Update Status
            </a>
            <form method="post" action="{{ path('app_adoption_delete', {id: adoption.id}) }}" onsubmit="return confirm('Are you sure you want to delete this adoption request? This action cannot be undone.')" class="mb-0">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ adoption.id) }}">
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash-alt mr-2"></i> Delete Request
                </button>
            </form>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}
