{% extends 'base.html.twig' %}

{% block title %}Edit Adoption Request — PAWHUB{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        .page-wrapper {
            padding: 40px;
            background: linear-gradient(135deg, #FFF8F3 0%, #FFEEE5 50%, #FFE8E8 100%);
            min-height: calc(100vh - 80px);
        }
        .adoption-container {
            max-width: 560px;
            margin: 0 auto;
        }
        .adoption-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .adoption-header h1 {
            font-family: 'Fredoka', cursive, sans-serif;
            color: #2D3436;
            font-size: 2.25rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .adoption-header p {
            color: #636E72;
            font-size: 1rem;
        }
        .adoption-summary {
            background: #FFF8F3;
            border: 2px solid #FFE5E5;
            border-radius: 12px;
            padding: 1rem 1.25rem;
            margin-bottom: 1.5rem;
            color: #636E72;
            font-size: 0.95rem;
        }
        .adoption-summary strong { color: #2D3436; }
        .adoption-form {
            background: white;
            border-radius: 20px;
            padding: 2rem 2.5rem;
            box-shadow: 0 10px 40px rgba(232, 90, 113, 0.08);
        }
        .form-group { margin-bottom: 1.25rem; }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #636E72;
        }
        .form-control {
            width: 100%;
            padding: 0.8rem 1rem;
            border: 2px solid #FFE5E5;
            border-radius: 12px;
            font-size: 1rem;
            background: white;
        }
        .form-actions {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 2px solid #FFE5E5;
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .btn-primary {
            background: linear-gradient(90deg, #E85A71 0%, #FF8C42 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 8px;
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
        }
        .btn-secondary {
            color: #E85A71;
            text-decoration: none;
            font-weight: 600;
            padding: 14px 20px;
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="adoption-container">
        <div class="adoption-header">
            <h1>✏️ Update Status</h1>
            <p>Change the status for this adoption request.</p>
        </div>
        <div class="adoption-summary">
            <div><strong>Pet:</strong> {{ adoption.pet ? adoption.pet.name : 'N/A' }}</div>
            <div><strong>Requester:</strong> {{ adoption.user ? adoption.user.username : 'N/A' }}</div>
            <div><strong>Submitted:</strong> {{ adoption.createdAt ? adoption.createdAt|date('Y-m-d') : 'N/A' }}</div>
            <div><strong>Current status:</strong> {{ adoption.status }}</div>
        </div>
        <div class="adoption-form">
            <form method="post" action="{{ path('app_adoption_edit', {id: adoption.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('adoption_update' ~ adoption.id) }}">
                <div class="form-group">
                    <label for="status">Status</label>
                    <select id="status" name="status" class="form-control" required>
                        {% for status in statuses %}
                            <option value="{{ status }}" {{ adoption.status == status ? 'selected' : '' }}>
                                {{ status }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="form-actions">
                    <button type="submit" class="btn-primary">Update Request</button>
                    <a href="{{ path('app_adoption') }}" class="btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
