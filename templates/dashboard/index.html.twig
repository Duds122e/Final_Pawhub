{% extends 'base.html.twig' %}

{% block title %}Dashboard - PAWHUB{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        .dashboard-header {
            background: white;
            padding: 1rem 2rem;
            box-shadow: 0 2px 20px rgba(232, 90, 113, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .dashboard-header-content {
            display: flex;
            align-items: center;
            max-width: 1200px;
            margin: 0 auto;
            justify-content: space-between;
        }

        .dashboard-header-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .dashboard-header img {
            height: 45px;
            width: auto;
        }

        .dashboard-header h1 {
            margin: 0;
            font-size: 1.8rem;
            color: #2D3436;
            font-weight: 700;
            font-family: 'Fredoka', cursive, sans-serif;
        }

        .dashboard-header h1 span {
            color: #E85A71;
        }

        .user-menu {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, #FF8C42 0%, #E85A71 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
        }

        .dashboard-wrapper {
            padding: 40px;
            background: linear-gradient(135deg, #FFF8F3 0%, #FFEEE5 50%, #FFE8E8 100%);
            min-height: calc(100vh - 80px);
        }

        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
        }

        .dashboard-welcome {
            margin-bottom: 30px;
        }

        .dashboard-welcome h2 {
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 2rem;
            color: #2D3436;
            margin: 0 0 10px 0;
        }

        .dashboard-welcome p {
            color: #636E72;
            font-size: 1rem;
            margin: 0;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 25px;
            margin-bottom: 40px;
        }

        .dashboard-card {
            background: white;
            border: none;
            border-radius: 20px;
            padding: 30px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(232, 90, 113, 0.08);
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

        .dashboard-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #FF8C42 0%, #E85A71 100%);
        }

        .dashboard-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 60px rgba(232, 90, 113, 0.15);
        }

        .dashboard-card-icon {
            width: 60px;
            height: 60px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 1.5rem;
        }

        .dashboard-card:nth-child(1) .dashboard-card-icon {
            background: #FFE5E5;
            color: #E85A71;
        }

        .dashboard-card:nth-child(2) .dashboard-card-icon {
            background: #FFF3E0;
            color: #FF8C42;
        }

        .dashboard-card:nth-child(3) .dashboard-card-icon {
            background: #E8F5E9;
            color: #4CAF50;
        }

        .dashboard-card:nth-child(4) .dashboard-card-icon {
            background: #E3F2FD;
            color: #2196F3;
        }

        .dashboard-card h3 {
            margin: 0 0 15px 0;
            color: #636E72;
            font-size: 0.9rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .dashboard-card .number {
            font-size: 2.5rem;
            font-weight: 700;
            color: #2D3436;
            font-family: 'Fredoka', cursive, sans-serif;
            line-height: 1;
        }

        .quick-actions {
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(232, 90, 113, 0.08);
        }

        .quick-actions h3 {
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 1.3rem;
            color: #2D3436;
            margin: 0 0 20px 0;
        }

        .action-buttons {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
        }

        .action-btn {
            padding: 12px 24px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .action-btn-primary {
            background: linear-gradient(135deg, #FF8C42 0%, #E85A71 100%);
            color: white;
            box-shadow: 0 4px 15px rgba(232, 90, 113, 0.3);
        }

        .action-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(232, 90, 113, 0.4);
        }

        .action-btn-secondary {
            background: #F8F9FA;
            color: #2D3436;
            border: 2px solid #E5E5E5;
        }

        .action-btn-secondary:hover {
            border-color: #E85A71;
            color: #E85A71;
        }

        .live-refresh-pulse .dashboard-card .number {
            animation: liveRefreshFlash 1.2s ease;
        }

        @keyframes liveRefreshFlash {
            0% { color: #2D3436; }
            40% { color: #E85A71; transform: scale(1.05); }
            100% { color: #2D3436; transform: scale(1); }
        }
    </style>
{% endblock %}

{% block body %}
<header class="dashboard-header">
    <div class="dashboard-header-content">
        <div class="dashboard-header-left">
            <img src="{{ asset('images/logo/logo-charity.png') }}" alt="PAWHUB Logo">
            <h1>PAW<span>HUB</span> Dashboard</h1>
        </div>
        <div class="user-menu">
            <div class="user-avatar">
                <i class="fas fa-user"></i>
            </div>
        </div>
    </div>
</header>

<div class="dashboard-wrapper"
     data-auto-refresh="dashboard"
     data-refresh-url="{{ path('admin_refresh_dashboard_stats') }}"
     data-refresh-version="">
    <div class="dashboard-container">
        <div class="dashboard-welcome">
            <h2>Welcome back! 🐾</h2>
            <p>Here's what's happening at PAWHUB today</p>
        </div>
        
        <div class="dashboard-grid">
            <div class="dashboard-card">
                <div class="dashboard-card-icon">
                    <i class="fas fa-paw"></i>
                </div>
                <h3>Total Pets</h3>
                <div class="number" data-stat="pets">{{ pets }}</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-card-icon">
                    <i class="fas fa-heart"></i>
                </div>
                <h3>Pending Adoptions</h3>
                <div class="number" data-stat="pending">{{ pending }}</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-card-icon">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h3>Appointments</h3>
                <div class="number" data-stat="appointments">{{ appointments }}</div>
            </div>
            <div class="dashboard-card">
                <div class="dashboard-card-icon">
                    <i class="fas fa-spa"></i>
                </div>
                <h3>Services</h3>
                <div class="number" data-stat="services">{{ services }}</div>
            </div>
        </div>

        <div class="quick-actions">
            <h3>Quick Actions</h3>
            <div class="action-buttons">
                <a href="{{ path('app_pet_new') }}" class="action-btn action-btn-primary">
                    <i class="fas fa-plus"></i> Add Pet
                </a>
                <a href="{{ path('app_service') }}" class="action-btn action-btn-secondary">
                    <i class="fas fa-list"></i> View Services
                </a>
                <a href="{{ path('appointment_index') }}" class="action-btn action-btn-secondary">
                    <i class="fas fa-calendar"></i> Appointments
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
