{% extends 'base.html.twig' %}

{% block title %}New Service — PAWHUB{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        .page-wrapper {
            padding: 40px;
            background: linear-gradient(135deg, #FFF8F3 0%, #FFEEE5 50%, #FFE8E8 100%);
            min-height: calc(100vh - 80px);
        }
        .service-container {
            max-width: 700px;
            margin: 0 auto;
        }
        .service-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .service-header h1 {
            font-family: 'Fredoka', cursive, sans-serif;
            color: #2D3436;
            font-size: 2.25rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .service-header p {
            color: #636E72;
            font-size: 1rem;
            max-width: 500px;
            margin: 0 auto;
        }
        .service-form {
            background: white;
            border-radius: 20px;
            padding: 2rem 2.5rem;
            box-shadow: 0 10px 40px rgba(232, 90, 113, 0.08);
        }
        .form-group {
            margin-bottom: 1.5rem;
        }
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: #2D3436;
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
        }
        .form-control {
            width: 100%;
            padding: 0.85rem 1rem;
            border: 2px solid #FFE5E5;
            border-radius: 12px;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            transition: all 0.2s ease;
            background: white;
        }
        .form-control:focus {
            border-color: #E85A71;
            box-shadow: 0 0 0 3px rgba(232, 90, 113, 0.1);
            outline: none;
        }
        .form-actions {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 2px solid #FFE5E5;
            display: flex;
            justify-content: center;
            gap: 1rem;
        }
        .btn-primary {
            background: linear-gradient(90deg, #E85A71 0%, #FF8C42 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 8px;
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 4px 15px rgba(232, 90, 113, 0.3);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(232, 90, 113, 0.4);
        }
        .form-error-message,
        .invalid-feedback,
        ul.form-errors li {
            color: #c0392b;
            font-size: 0.9rem;
            margin-top: 0.35rem;
        }
        @media (max-width: 768px) {
            .page-wrapper {
                padding: 20px;
            }
            .service-form {
                padding: 1.5rem;
            }
            .service-header h1 {
                font-size: 1.75rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="service-container">
        <div class="service-header">
            <h1>✨ Create New Service</h1>
            <p>Add a new service offering to your veterinary center.</p>
        </div>
        <div class="service-form">
            {{ form_start(form) }}
                {{ form_errors(form) }}
                {{ form_row(form.name, {'attr': {'class': 'form-control'}}) }}
                {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                {{ form_row(form.price, {'attr': {'class': 'form-control', 'step': '0.01', 'min': '0'}}) }}
                <div class="form-actions">
                    {{ form_widget(form.save, {
                        'label': '+ Create Service',
                        'attr': {'class': 'btn-primary'}
                    }) }}
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
