{% extends 'base.html.twig' %}

{% block title %}New Appointment — PAWHUB{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        .page-wrapper {
            padding: 40px;
            background: linear-gradient(135deg, #FFF8F3 0%, #FFEEE5 50%, #FFE8E8 100%);
            min-height: calc(100vh - 80px);
        }
        .page-container {
            max-width: 800px;
            margin: 0 auto;
        }
        .page-header {
            margin-bottom: 30px;
        }
        .page-header h2 {
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 2rem;
            color: #2D3436;
            margin: 0;
        }
        .form-card {
            background: white;
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(232, 90, 113, 0.08);
        }
        .form-card h3 {
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 1.3rem;
            color: #E85A71;
            margin: 25px 0 20px 0;
            padding-bottom: 10px;
            border-bottom: 2px solid #FFE5E5;
        }
        .form-card h3:first-of-type {
            margin-top: 0;
        }
        .form-row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 20px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-weight: 600;
            color: #636E72;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }
        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #FFE5E5;
            border-radius: 12px;
            font-size: 1rem;
            transition: border-color 0.3s ease, box-shadow 0.3s ease;
            background: #FFF8F3;
        }
        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: #E85A71;
            box-shadow: 0 0 0 3px rgba(232, 90, 113, 0.1);
        }
        .btn-primary {
            background: linear-gradient(90deg, #E85A71 0%, #FF8C42 100%);
            color: white;
            padding: 14px 28px;
            border-radius: 8px;
            border: none;
            font-family: 'Fredoka', cursive, sans-serif;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(232, 90, 113, 0.3);
            margin-top: 10px;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(232, 90, 113, 0.4);
        }
        .btn-link {
            display: inline-block;
            color: #E85A71;
            text-decoration: none;
            font-weight: 600;
            margin-top: 15px;
            transition: color 0.3s;
        }
        .btn-link:hover {
            color: #FF8C42;
        }
        hr {
            border: none;
            border-top: 1px solid #FFE5E5;
            margin: 30px 0;
        }
        @media (max-width: 600px) {
            .form-row {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="page-container">
        <div class="page-header">
            <h2>📅 New Appointment</h2>
        </div>
        
        <div class="form-card">
            {{ form_start(form) }}
                <h3>Appointment Details</h3>
                <div class="form-row">
                    <div class="form-group">{{ form_row(form.dateTime) }}</div>
                    <div class="form-group">{{ form_row(form.location) }}</div>
                </div>
                <div class="form-group">{{ form_row(form.reason) }}</div>
                
                <hr>
                
                <h3>Owner/Client Information</h3>
                <div class="form-row">
                    <div class="form-group">{{ form_row(form.ownerName) }}</div>
                    <div class="form-group">{{ form_row(form.contactPhone) }}</div>
                </div>
                <div class="form-group">{{ form_row(form.address) }}</div>
                <div class="form-group">{{ form_row(form.emergencyContact) }}</div>
                
                <hr>
                
                <h3>Pet Details</h3>
                <div class="form-group">{{ form_row(form.petName) }}</div>
                <div class="form-row">
                    <div class="form-group">{{ form_row(form.petSpecies) }}</div>
                    <div class="form-group">{{ form_row(form.petBreed) }}</div>
                </div>
                <div class="form-row">
                    <div class="form-group">{{ form_row(form.petColor) }}</div>
                    <div class="form-group">{{ form_row(form.petSex) }}</div>
                </div>
                <div class="form-row">
                    <div class="form-group">{{ form_row(form.petSpayNeuter) }}</div>
                    <div class="form-group">{{ form_row(form.petWeight) }}</div>
                </div>
                <div class="form-row">
                    <div class="form-group">{{ form_row(form.petDob) }}</div>
                    <div class="form-group">{{ form_row(form.petMicrochip) }}</div>
                </div>
                
                <button class="btn-primary">Create Appointment</button>
            {{ form_end(form) }}
            
            <a href="{{ path('appointment_index') }}" class="btn-link">← Back to list</a>
        </div>
    </div>
</div>
{% endblock %}
