{% extends 'base.html.twig' %}

{% block title %}Appointment Details — PAWHUB{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        .page-wrapper {
            padding: 40px;
            background: linear-gradient(135deg, #FFF8F3 0%, #FFEEE5 50%, #FFE8E8 100%);
            min-height: calc(100vh - 80px);
        }
        .appointment-container {
            max-width: 800px;
            margin: 0 auto;
        }
        .appointment-header {
            text-align: center;
            margin-bottom: 2rem;
        }
        .appointment-header h1 {
            font-family: 'Fredoka', cursive, sans-serif;
            color: #2D3436;
            font-size: 2.25rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        .appointment-card {
            background: white;
            border-radius: 20px;
            padding: 2rem 2.5rem;
            box-shadow: 0 10px 40px rgba(232, 90, 113, 0.08);
        }
        .details-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }
        .details-table tr {
            border-bottom: 1px solid #FFE5E5;
        }
        .details-table tr:last-child {
            border-bottom: none;
        }
        .details-table th {
            text-align: left;
            padding: 1rem;
            background: #FFF8F3;
            font-family: 'Fredoka', cursive, sans-serif;
            color: #E85A71;
            font-weight: 600;
            width: 30%;
            border-radius: 12px 0 0 12px;
        }
        .details-table td {
            padding: 1rem;
            color: #2D3436;
            font-weight: 500;
        }
        .details-table tr:first-child th {
            border-radius: 12px 0 0 0;
        }
        .details-table tr:last-child th {
            border-radius: 0 0 0 12px;
        }
        .form-actions {
            margin-top: 2rem;
            padding-top: 1.5rem;
            border-top: 2px solid #FFE5E5;
            display: flex;
            justify-content: center;
            gap: 1rem;
        }
        .btn-primary {
            background: linear-gradient(90deg, #E85A71 0%, #FF8C42 100%);
            color: white;
            border: none;
            padding: 14px 28px;
            border-radius: 8px;
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            box-shadow: 0 4px 15px rgba(232, 90, 113, 0.3);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(232, 90, 113, 0.4);
        }
        .btn-secondary {
            background: white;
            color: #636E72;
            border: 2px solid #636E72;
            padding: 14px 28px;
            border-radius: 8px;
            font-family: 'Fredoka', cursive, sans-serif;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        .btn-secondary:hover {
            background: #636E72;
            color: white;
        }
        @media (max-width: 768px) {
            .page-wrapper {
                padding: 20px;
            }
            .appointment-card {
                padding: 1.5rem;
            }
            .appointment-header h1 {
                font-size: 1.75rem;
            }
            .details-table th,
            .details-table td {
                display: block;
                width: 100%;
            }
            .details-table th {
                border-radius: 12px 12px 0 0;
            }
            .details-table td {
                padding-top: 0.5rem;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div class="appointment-container">
        <div class="appointment-header">
            <h1>📅 Appointment Details</h1>
        </div>
        <div class="appointment-card">
            <table class="details-table">
                <tr>
                    <th>ID</th>
                    <td>{{ appointment.id }}</td>
                </tr>
                <tr>
                    <th>Date & Time</th>
                    <td>{{ appointment.dateTime|date('Y-m-d H:i') }}</td>
                </tr>
                <tr>
                    <th>User</th>
                    <td>{{ appointment.user.username }}</td>
                </tr>
                <tr>
                    <th>Pet</th>
                    <td>{{ appointment.pet.name }}</td>
                </tr>
            </table>
            <div class="form-actions">
                <a href="{{ path('appointment_edit', {'id': appointment.id}) }}" class="btn-primary">
                    <i class="fas fa-edit"></i> Update
                </a>
                <a href="{{ path('appointment_index') }}" class="btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to list
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}